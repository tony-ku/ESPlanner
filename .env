# ESPlanner configuration. Edit the paths below to point at your own data.

PORT=3000

# One-minute OHLCV file (overwritten each minute with a single row):
#   Time,Symbol,Open,High,Low,Close,Volume
MINUTE_FILE=C:/path/to/one_min_data.csv.txt

# Sierra Chart-style price levels CSV.
LEVELS_FILE=C:/path/to/cn.csv

# Directory of dated markdown trading plans (trading-plan-YYYY-MM-DD.md).
PLANS_DIR=C:/path/to/trading_plan

POLL_MS=1000
HISTORY_DAYS=2
SESSION_FILE=./session_bars.csv
