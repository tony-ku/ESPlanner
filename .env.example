# Copy this file to .env and adjust paths as needed.

# HTTP port for the local web server
PORT=3000

# Minute OHLCV file (overwritten each minute with a single row).
# Format: Time,Symbol,Open,High,Low,Close,Volume
MINUTE_FILE=C:/Users/tonyk/es_trade_plans/data/one_min_data.csv.txt

# Price levels CSV (Sierra Chart notification export style).
LEVELS_FILE=C:/Users/tonyk/Documents/tinyserver/cn.csv

# Directory containing dated markdown trading plans (trading-plan-YYYY-MM-DD.md).
PLANS_DIR=C:/Users/tonyk/es_trade_plans/trading_plan

# How often to re-read the minute file (milliseconds).
POLL_MS=1000

# Rolling chart window (days). Bars older than this from the newest bar are dropped.
HISTORY_DAYS=2

# Where to persist observed bars so reloads keep context.
SESSION_FILE=./session_bars.csv
