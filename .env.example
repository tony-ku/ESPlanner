# Copy this file to .env and adjust paths for your machine.

# HTTP port for the local web server.
PORT=3000

# One-minute OHLCV file. The writer is expected to OVERWRITE this file
# each minute with a single row in the format:
#   Time,Symbol,Open,High,Low,Close,Volume
# Example row:
#   15:14:03,ESM6,7002,7003,7002,7002.5,966
MINUTE_FILE=C:/path/to/one_min_data.csv.txt

# Sierra Chart-style price levels CSV. Required header columns:
#   Symbol, Price Level, Note, Foreground Color, Background Color
LEVELS_FILE=C:/path/to/cn.csv

# Directory containing dated markdown trading plans named
# trading-plan-YYYY-MM-DD.md. Today's plan is auto-selected.
PLANS_DIR=C:/path/to/trading_plan

# How often to re-read MINUTE_FILE (milliseconds).
POLL_MS=1000

# Rolling chart window (days). Bars older than HISTORY_DAYS from the
# newest observed bar are dropped from the chart and session file.
HISTORY_DAYS=2

# Where to persist observed bars so reloads keep chart context.
# Safe to delete at any time; a fresh session starts on the next bar.
SESSION_FILE=./session_bars.csv
